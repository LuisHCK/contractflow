<!DOCTYPE html>
<html lang="en" data-theme="<%= locals.theme || 'light' %>">
<%- include('../partials/head', {title: `ContractorPay | ${locals.title}`}) %>

    <body>
        <%- include('../partials/navigation') %>
        <main class="container is-max-desktop py-6">
            <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                <ul>
                    <li><a href="/">Home</a></li>
                    <li class="is-active">
                        <a href="#" aria-current="page" class="has-text-dark"> <%= locals.title %> </a>
                    </li>
                </ul>
            </nav>

            <section class="px-4">
                <div class="is-flex is-justify-content-space-between is-align-items-center">
                    <h1 class="title is-1 is-family-sans-serif"><%= locals.title %></h1>
                    <% if (locals.showCreate) { %>
                        <a href="<%= locals.createPath %>" class="button is-primary">
                            Create
                        </a>
                    <% } %>
                </div>

                <% if (locals.description) { %>
                    <h2 class="subtitle"><%= locals.description %></h2>
                <% } %>

                <div class="box">
                    <%- include('../partials/table', { data, fields }) %>
                </div>
            </section>
        </main>
    </body>

</html>
