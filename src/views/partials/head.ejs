<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>
        <% if (locals.title) { %>
            <%= locals.title %>
        <% } else { %>
            ContractorPay | Streamline your payments, simplify your life
        <% } %>
    </title>
    <meta
        name="description"
        content="Plan, budget, and track projects with confidence. Create, manage, and pay contractors with ease."
    />
    <meta
        name="keywords"
        content="contractor, pay, payment, project, budget, track, manage, create, pay, ease"
    />
    <meta name="author" content="ContractorPay" />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#111827" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- Open Graph / Social -->
    <meta
        property="og:title"
        content="<%= locals.title || 'ContractorPay | Streamline your payments, simplify your life' %>"
    />
    <meta
        property="og:description"
        content="Plan, budget, and track projects with confidence. Create, manage, and pay contractors with ease."
    />
    <meta property="og:type" content="website" />
    <% if (locals.ogUrl) { %>
        <meta property="og:url" content="<%= locals.ogUrl %>" />
    <% } %>
    <meta property="og:image" content="/apple-touch-icon.png" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
        name="twitter:title"
        content="<%= locals.title || 'ContractorPay | Streamline your payments, simplify your life' %>"
    />
    <meta
        name="twitter:description"
        content="Plan, budget, and track projects with confidence. Create, manage, and pay contractors with ease."
    />
    <meta name="twitter:image" content="/apple-touch-icon.png" />

    <% if (locals.canonical) { %>
        <link rel="canonical" href="<%= locals.canonical %>" />
    <% } %>

    <!-- Load custom scripts -->
     <% if (locals.scripts) { %>
        <% locals.scripts.forEach(script => { %>
            <script src="<%= script %>" defer></script>
        <% }); %>
    <% } %>

    <!-- Prefetchers -->
    <link rel="prefetch" href="/projects" />
    <link rel="prefetch" href="/contractors" />

    <!-- Custom styles -->
    <link rel="stylesheet" href="/css/main.css" />

    <!-- App Scripts -->
    <script src="/js/iframe-controller.js" defer></script>
    <script src="/js/iframe-modal.js" defer></script>
    <script src="/scripts.js" defer></script>
</head>
