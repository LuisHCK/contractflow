<!DOCTYPE html>
<html lang="<%= locale %>" data-theme="<%= locals.theme || 'light' %>">
    <%- include('../partials/head') %>
    <body>
        <%- include('../partials/navigation') %>

        <main>
            <!-- Login Section -->
            <section class="hero is-fullheight-with-navbar hero-background">
                <div class="hero-body">
                    <div class="container is-max-desktop">
                        <div class="columns is-centered">
                            <div class="column is-8-tablet is-6-desktop">
                                <!-- Header -->
                                <div class="has-text-centered mb-5">
                                    <h1 class="title is-3 is-family-serif">Welcome back</h1>
                                    <p class="subtitle is-6 has-text-grey">
                                        Sign in to your ContractorPay account
                                    </p>
                                </div>

                                <!-- Login Form Card -->
                                <div class="box login-card">
                                    <form method="post" action="/login">
                                        <div class="field">
                                            <label class="label" for="email">Email address</label>
                                            <div class="control">
                                                <input
                                                    id="email"
                                                    name="email"
                                                    type="email"
                                                    class="input"
                                                    placeholder="you@example.com"
                                                    required
                                                />
                                            </div>
                                        </div>

                                        <div class="field">
                                            <label class="label mb-0" for="password">Password</label>
                                            <div class="control">
                                                <input
                                                    id="password"
                                                    name="password"
                                                    type="password"
                                                    class="input"
                                                    placeholder="Enter your password"
                                                    required
                                                />
                                            </div>
                                            <p class="is-size-7 has-text-grey has-text-right mt-1">
                                                <a href="#">
                                                    Forgot password?
                                                </a>
                                            </p>
                                        </div>

                                        <div class="field mt-5">
                                            <div class="control">
                                                <button
                                                    type="submit"
                                                    class="button is-dark is-fullwidth"
                                                >
                                                    Sign in
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>

                                <!-- Help text -->
                                <p class="has-text-centered is-size-7 has-text-grey mt-4">
                                    Need access to ContractorPay?
                                    <a href="#" class="has-text-dark">
                                        &nbsp;Contact your administrator
                                    </a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <footer class="footer">
            <div class="container is-max-widescreen">
                <div class="columns is-vcentered">
                    <div class="column">
                        <div class="is-flex is-align-items-center" style="gap: 1.5rem">
                            <a href="#" class="has-text-grey hover:has-text-black">Privacy</a>
                            <a href="#" class="has-text-grey hover:has-text-black">Terms</a>
                            <a href="#" class="has-text-grey hover:has-text-black">Contact</a>
                        </div>
                    </div>
                    <div class="column is-narrow">
                        <p class="is-size-7 has-text-grey">
                            © 2026 ContractorPay. All rights reserved.
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>
