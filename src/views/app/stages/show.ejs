<!DOCTYPE html>
<html lang="en" data-theme="<%= locals.theme || 'light' %>">
<%- include('../../partials/head', { title: `ContractorPay | ${project.name} stages` }) %>

    <body>
        <%- include('../../partials/navigation') %>

            <main class="container is-max-widescreen py-6 px-4">
                <!-- Breadcrumbs -->
                <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                    <ul>
                        <li><a href="/"> <%= __('breadcrumb_home') %> </a></li>
                        <li><a href="/projects"> <%= __('breadcrumb_projects') %> </a></li>
                        <li><a href="/projects/show/<%= project.id %>">
                                <%= project.name %>
                            </a></li>
                        <li class="is-active">
                            <a href="#" aria-current="page" class="has-text-dark">
                                <%= stage.name %>
                            </a>
                        </li>
                    </ul>
                </nav>

                <section class="is-flex is-justify-content-space-between is-align-items-center">
                    <h1 class="title is-1">
                        <%= stage.name %>
                    </h1>

                    <div>
                        <a href="/projects/show/<%= project.id %>/stages/edit/<%= stage.id %>?backto=details"
                            class="button is-primary">
                            <%= __('detail_edit') %>
                        </a>
                        <a href="/projects/show/<%= project.id %>/stages/show/<%= stage.id %>/payments/create"
                            class="button is-secondary">
                            <%= __('stages_register_payment') %>
                        </a>
                        <% if (payments.length > 0) { %>
                            <a href="/projects/show/<%= project.id %>/stages/print/<%= stage.id %>" class="button is-info">
                                <%= __('print_report', 'Print report') %>
                            </a>
                        <% } %>
                    </div>

                </section>

                <h2 class="subtitle"><%= stage.description %></h2>

                <section>
                    <h2 class="title is-5"><%= __('payments_stage_title', 'Payments') %></h2>
                </section>

                <div class="mt-4">
                    <% if (payments.length === 0) { %>
                        <div class="notification is-warning">
                            <%= __('stages_no_payments', 'No payments registered for this stage.') %>
                        </div>
                    <% } else { %>
                        <div class="table-container">
                            <table class="table is-fullwidth is-striped is-hoverable is-narrow">
                                <thead>
                                    <tr>
                                        <th><%= __('payment_number', 'Payment') %></th>
                                        <th><%= __('invoice_amount') %></th>
                                        <th><%= __('contractor_name', 'Contractor / Category') %></th>
                                        <th><%= __('details', 'Details') %></th>
                                        <th><%= __('actions', 'Actions') %></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% payments.forEach(payment => { %>
                                        <tr>
                                            <td>
                                                <div class="has-text-weight-semibold">
                                                    <%= __('payment_number', 'Payment #') %><%= payment.paymentNumber %>
                                                </div>
                                                <div class="mt-1">
                                                    <span class="tag is-light is-size-7">
                                                        <%= __('invoice_payment_date') %>: <%= payment.createdAt %>
                                                    </span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="tag is-success">
                                                    <%= formatToCurrency(payment.amount) %>
                                                </span>
                                            </td>
                                            <td>
                                                <div>
                                                    <span class="has-text-weight-semibold"><%= __('contractor_name') %></span><br>
                                                    <%= payment.contractor?.name %>
                                                </div>
                                                <div class="mt-2">
                                                    <span class="has-text-weight-semibold">
                                                        <%= __('payment_categories_list_title') %>
                                                    </span>
                                                    <br>
                                                    <%= payment.paymentCategory?.name %>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <span class="has-text-weight-semibold">
                                                        <%= __('invoice_payment_method') %>
                                                    </span>
                                                    <br>
                                                    <span class="tag is-info is-light">
                                                        <%= payment.paymentMethod %>
                                                    </span>
                                                </div>
                                                <div class="mt-2">
                                                    <span class="has-text-weight-semibold">
                                                        <%= __('evidence_description') %>
                                                    </span>
                                                    <br>
                                                    <p class="mb-1"><%= payment.description %></p>
                                                </div>
                                                <div class="mt-2">
                                                    <span class="has-text-weight-semibold">
                                                        <%= __('evidence_attachment') %>
                                                    </span>
                                                    <br>
                                                    <% if (payment.evidences?.length > 0) { %>
                                                        <ul>
                                                            <% payment.evidences.forEach(evidence => { %>
                                                                <li>
                                                                    <a href="/<%= evidence.filePath %>" target="_blank">
                                                                        <%= evidence.fileName %>
                                                                    </a>
                                                                </li>
                                                            <% }) %>
                                                        </ul>
                                                    <% } else { %>
                                                        <span class="tag is-light">
                                                            <%= __('evidence_no_evidence', 'No evidence registered') %>
                                                        </span>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td class="is-nowrap">
                                                <div class="buttons are-small is-flex is-flex-direction-column is-align-items-flex-end">
                                                    <a href="/payments/print/<%= payment.id %>" class="button is-link is-light">
                                                        <%= __('print', 'Print') %>
                                                    </a>
                                                    <a href="/payments/show/<%= payment.id %>/evidences/create" class="button is-info is-light">
                                                        <%= __('evidences_create_title', 'Register evidence') %>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </main>
    </body>

</html>
