<!DOCTYPE html>
<html lang="en" data-theme="<%= locals.theme || 'light' %>">
<%- include('../../partials/head', { title: `ContractorPay | ${project.name} stages` }) %>

    <body>
        <%- include('../../partials/navigation') %>

            <main class="container is-max-desktop py-6 px-4">
                <!-- Breadcrumbs -->
                <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                    <ul>
                        <li><a href="/"> <%= __('breadcrumb_home') %> </a></li>
                        <li><a href="/projects"> <%= __('breadcrumb_projects') %> </a></li>
                        <li><a href="/projects/show/<%= project.id %>">
                                <%= project.name %>
                            </a></li>
                        <li class="is-active">
                            <a href="#" aria-current="page" class="has-text-dark">
                                <%= stage.name %>
                            </a>
                        </li>
                    </ul>
                </nav>

                <section class="is-flex is-justify-content-space-between is-align-items-center">
                    <h1 class="title is-1 is-family-sans-serif">
                        <%= stage.name %>
                    </h1>

                    <div>
                        <a href="/projects/show/<%= project.id %>/stages/edit/<%= stage.id %>?backto=details"
                            class="button is-primary">
                            <%= __('detail_edit') %>
                        </a>
                        <a href="/projects/show/<%= project.id %>/stages/show/<%= stage.id %>/payments/create"
                            class="button is-secondary">
                            <%= __('stages_register_payment') %>
                        </a>
                        <% if (payments.length > 0) { %>
                            <a href="/projects/show/<%= project.id %>/stages/print/<%= stage.id %>" class="button is-info">
                                <%= __('print_report', 'Print report') %>
                            </a>
                        <% } %>
                    </div>

                </section>

                <h2 class="subtitle"><%= stage.description %></h2>

                <section>
                    <h2 class="title is-5"><%= __('payments_stage_title', 'Payments') %></h2>
                </section>

                <div class="mt-4">
                    <ul class="columns is-mobile is-multiline">
                        <% if (payments.length === 0) { %>
                            <li class="column is-full">
                                <div class="notification is-warning">
                                    <%= __('stages_no_payments', 'No payments registered for this stage.') %>
                                </div>
                            </li>
                        <% } %>

                        <% payments.forEach(payment=> { %>
                            <li class="column is-half-desktop is-one-third-tablet">
                                <div class="card">
                                    <header class="card-header">
                                        <p class="card-header-title">
                                            <%= __('payment_number', 'Payment #') %><%= payment.paymentNumber %>
                                        </p>
                                    </header>
                                    <div class="card-content">
                                        <div class="content">
                                            <div class="fixed-grid has-2-cols">
                                                <div class="grid">
                                                    <div class="cell">
                                                        <div class="has-text-weight-semibold"><%= __('invoice_amount') %></div>
                                                        <span class="tag is-success">
                                                            <%= payment.amount.toLocaleString('en-US', {
                                                                style: 'currency' , currency: 'USD' }) %>
                                                        </span>
                                                    </div>

                                                    <div class="cell">
                                                        <div class="has-text-weight-semibold"><%= __('invoice_payment_date') %></div>
                                                        <span class="tag">
                                                            <%= payment.createdAt %>
                                                        </span>
                                                    </div>

                                                    <div class="cell">
                                                        <div class="has-text-weight-semibold"><%= __('invoice_payment_method') %></div>
                                                        <span class="tag is-info">
                                                            <%= payment.paymentMethod %>
                                                        </span>
                                                    </div>

                                                    <div class="cell">
                                                        <div class="has-text-weight-semibold"><%= __('contractor_name') %></div>
                                                        <%= payment.contractor?.name %>
                                                    </div>

                                                    <div class="cell is-col-span-2">
                                                        <div class="has-text-weight-semibold"><%= __('payment_categories_list_title') %></div>
                                                        <%= payment.paymentCategory?.name %>
                                                    </div>

                                                    <div class="cell is-col-span-2">
                                                        <div class="has-text-weight-semibold"><%= __('evidence_description') %></div>
                                                        <p>
                                                            <%= payment.description %>
                                                        </p>
                                                    </div>

                                                    <div class="cell is-col-span-2">
                                                        <div class="has-text-weight-semibold"><%= __('evidence_attachment') %></div>
                                                        <% if (payment.evidences?.length > 0) { %>
                                                            <ul>
                                                                <% payment.evidences.forEach(evidence => { %>
                                                                    <li>
                                                                        <a href="/<%= evidence.filePath %>" target="_blank">
                                                                            <%= evidence.fileName %>
                                                                        </a>
                                                                    </li>
                                                                <% }) %>
                                                            </ul>
                                                        <% } else { %>
                                                            <span class="tag is-light"><%= __('evidence_no_evidence', 'No evidence registered') %></span>
                                                        <% } %>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <footer class="card-footer">
                                        <a href="/payments/print/<%= payment.id %>" class="card-footer-item"><%= __('print', 'Print') %></a>
                                        <a href="/payments/show/<%= payment.id %>/evidences/create" class="card-footer-item"><%= __('evidences_create_title', 'Register evidence') %></a>
                                    </footer>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </main>
    </body>

</html>
