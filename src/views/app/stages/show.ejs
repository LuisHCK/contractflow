<!DOCTYPE html>
<html lang="en" data-theme="<%= locals.theme || 'light' %>">
<%- include('../../partials/head', { title: `ContractFlow | ${project.name} stages` }) %>

    <body>
        <%- include('../../partials/navigation') %>

            <main class="container is-max-widescreen py-6 px-4">
                <!-- Breadcrumbs -->
                <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                    <ul>
                        <li><a href="/"> <%= __('breadcrumb_home') %> </a></li>
                        <li><a href="/projects"> <%= __('breadcrumb_projects') %> </a></li>
                        <li><a href="/projects/show/<%= project.id %>">
                                <%= project.name %>
                            </a></li>
                        <li class="is-active">
                            <a href="#" aria-current="page" class="has-text-dark">
                                <%= stage.name %>
                            </a>
                        </li>
                    </ul>
                </nav>

                <section class="is-flex is-justify-content-space-between is-align-items-center">
                    <h1 class="title is-1">
                        <%= stage.name %>
                    </h1>

                    <div>
                        <a href="/projects/show/<%= project.id %>/stages/edit/<%= stage.id %>?backto=details"
                            class="button is-primary">
                            <%= __('detail_edit') %>
                        </a>
                        <a href="/projects/show/<%= project.id %>/stages/show/<%= stage.id %>/payments/create"
                            class="button is-secondary">
                            <%= __('stages_register_payment') %>
                        </a>
                        <% if (payments.length > 0) { %>
                            <a href="/projects/show/<%= project.id %>/stages/print/<%= stage.id %>" class="button is-info">
                                <%= __('print_report', 'Print report') %>
                            </a>
                        <% } %>
                    </div>

                </section>

                <h2 class="subtitle"><%= stage.description %></h2>

                <%- include('./partials/_stats', { stage, payments, formatToCurrency, __ }) %>

                <section>
                    <h2 class="title is-5"><%= __('payments_stage_title', 'Payments') %></h2>
                </section>

                <div class="mt-4">
                    <% if (payments.length === 0) { %>
                        <div class="notification is-warning">
                            <%= __('stages_no_payments', 'No payments registered for this stage.') %>
                        </div>
                    <% } else { %>
                        <%- include('./partials/_payments-table', { payments, formatToCurrency, __ }) %>
                    <% } %>
                </div>
            </main>
    </body>

</html>
