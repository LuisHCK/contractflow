<!DOCTYPE html>
<html lang="<%= locale %>" data-theme="<%= locals.theme || 'light' %>">
    <%- include('../../partials/head', { title: `ContractFlow | ${__(title)}` }) %>
    <body>
        <%- include('../../partials/navigation') %>
        <%- include('../../partials/flash-messages') %>

        <main class="container is-max-desktop py-6 px-4">
            <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                <ul>
                    <li><a href="/"> <%= __('breadcrumb_home') %> </a></li>
                    <li class="is-active">
                        <a href="#" aria-current="page" class="has-text-dark">
                            <%= __(title) %>
                        </a>
                    </li>
                </ul>
            </nav>

            <section>
                <div class="is-flex is-justify-content-space-between is-align-items-center mb-4">
                    <h1 class="title is-2 is-family-sans-serif"><%= __(title) %></h1>
                </div>

                <% actions.forEach(actionItem => { %>
                    <form action="<%= actionItem.action %>" method="post" class="form mb-5">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                        <div class="box">
                            <h2 class="title is-4 mb-2"><%= actionItem.title %></h2>
                            <% if (actionItem.description) { %>
                                <p class="subtitle is-6 has-text-grey mb-4"><%= actionItem.description %></p>
                            <% } %>

                            <% actionItem.fields.forEach(field => { %>
                                <div class="field mb-4">
                                    <label class="label" for="<%= field.name %>">
                                        <%= field.label %>
                                        <% if (field.required) { %>
                                            *
                                        <% } %>
                                    </label>
                                    <div class="control">
                                        <% if (field.type === 'textarea') { %>
                                            <textarea
                                                class="textarea"
                                                name="<%= field.name %>"
                                                id="<%= field.name %>"
                                                placeholder="<%= field.placeholder %>"
                                                <%= field.required ? 'required' : '' %>
                                            ><%= field.value || '' %></textarea>
                                        <% } else if (field.type === 'select') { %>
                                            <div class="select is-fullwidth">
                                                <select
                                                    name="<%= field.name %>"
                                                    id="<%= field.name %>"
                                                    <%= field.required ? 'required' : '' %>
                                                >
                                                    <% (field.options || []).forEach(option => { %>
                                                        <option
                                                            value="<%= option.value %>"
                                                            <%= option.selected ? 'selected' : '' %>
                                                        >
                                                            <%= option.label %>
                                                        </option>
                                                    <% }) %>
                                                </select>
                                            </div>
                                        <% } else { %>
                                            <input
                                                class="input"
                                                type="<%= field.type || 'text' %>"
                                                name="<%= field.name %>"
                                                id="<%= field.name %>"
                                                placeholder="<%= field.placeholder %>"
                                                value="<%= field.value || '' %>"
                                                <%= field.required ? 'required' : '' %>
                                            />
                                        <% } %>
                                    </div>

                                    <% if (field.help) { %>
                                        <p class="help"><%= field.help %></p>
                                    <% } %>
                                </div>
                            <% }) %>

                            <div>
                                <button class="button is-primary" type="submit">
                                    <%= actionItem.submitLabel %>
                                </button>
                            </div>
                        </div>
                    </form>
                <% }) %>
            </section>
        </main>
    </body>
</html>
