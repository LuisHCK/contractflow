<!DOCTYPE html>
<html lang="<%= locale %>" data-theme="<%= locals.theme || 'light' %>">
    <%- include('../../partials/head', { title: `ContractFlow | ${__(title)}` }) %>
    <body>
        <%- include('../../partials/navigation') %>

        <main class="container is-max-desktop py-6 px-4">
            <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                <ul>
                    <li><a href="/"> <%= __('breadcrumb_home') %> </a></li>
                    <li class="is-active">
                        <a href="#" aria-current="page" class="has-text-dark">
                            <%= __(title) %>
                        </a>
                    </li>
                </ul>
            </nav>

            <section>
                <div class="is-flex is-justify-content-space-between is-align-items-center mb-4">
                    <h1 class="title is-2 is-family-sans-serif"><%= __(title) %></h1>
                </div>

                <% if (typeof success !== 'undefined') { %>
                    <div class="notification is-success">
                        <button class="delete" onclick="this.parentNode.remove()"></button>
                        <%= success %>
                    </div>
                <% } %>

                <% if (typeof error !== 'undefined') { %>
                    <div class="notification is-danger">
                        <button class="delete" onclick="this.parentNode.remove()"></button>
                        <%= error %>
                    </div>
                <% } %>

                <form action="/settings" method="post" class="form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <% groups.forEach(group => { %>
                        <div class="box mb-5">
                            <h2 class="title is-4 mb-2"><%= group.title %></h2>
                            <% if (group.description) { %>
                                <p class="subtitle is-6 has-text-grey mb-4"><%= group.description %></p>
                            <% } %>

                            <% group.fields.forEach(field => { %>
                                <div class="field mb-4">
                                    <label class="label" for="<%= field.name %>">
                                        <%= field.label %>
                                        <% if (field.required) { %>
                                            *
                                        <% } %>
                                    </label>
                                    <div class="control">
                                        <% if (field.type === 'textarea') { %>
                                            <textarea
                                                class="textarea"
                                                name="<%= field.name %>"
                                                id="<%= field.name %>"
                                                placeholder="<%= field.placeholder %>"
                                                <%= field.required ? 'required' : '' %>
                                            ><%= field.value || '' %></textarea>
                                        <% } else { %>
                                            <input
                                                class="input"
                                                type="<%= field.type || 'text' %>"
                                                name="<%= field.name %>"
                                                id="<%= field.name %>"
                                                placeholder="<%= field.placeholder %>"
                                                value="<%= field.value || '' %>"
                                                <%= field.required ? 'required' : '' %>
                                            />
                                        <% } %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% }) %>

                    <div>
                        <button class="button is-primary" type="submit">
                            <%= __(submitLabel || 'submit') %>
                        </button>
                    </div>
                </form>
            </section>
        </main>
    </body>
</html>
