<!DOCTYPE html>
<html lang="<%= locale %>" data-theme="<%= locals.theme || 'light' %>">
    <%- include('../../partials/head', { title: 'Admin Panel - ContractorPay' }) %>

    <body>
        <%- include('../../partials/navigation') %>

        <main class="container is-max-widescreen py-6 px-4">
            <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                <ul>
                    <li><a href="/"><%= __('breadcrumb_home') %></a></li>
                    <li class="is-active">
                        <a href="#" aria-current="page" class="has-text-dark">Admin</a>
                    </li>
                </ul>
            </nav>

            <div class="mb-6">
                <h1 class="title is-1"><%= __('admin_panel_title') %></h1>
                <p class="subtitle"><%= __('admin_panel_subtitle') %></p>

                <!-- Export/Import Section -->
                <div class="box mt-5">
                    <div class="columns is-vcentered">
                        <div class="column">
                            <form action="/admin/import" method="post" enctype="multipart/form-data" class="is-flex is-align-items-center" style="gap:1rem">
                                <div class="file is-info has-name">
                                    <label class="file-label">
                                        <input class="file-input" type="file" name="data" accept="application/json" required>
                                        <span class="file-cta">
                                            <span class="file-icon">
                                                <i class="fas fa-upload"></i>
                                            </span>
                                            <span class="file-label">Import JSON</span>
                                        </span>
                                        <span class="file-name">Choose file…</span>
                                    </label>
                                </div>
                                <button type="submit" class="button is-info">
                                    <span class="icon"><i class="fas fa-file-import"></i></span>
                                    <span>Import Data</span>
                                </button>
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            </form>
                        </div>
                        <div class="column is-narrow">
                            <a href="/admin/export" class="button is-success">
                                <span class="icon"><i class="fas fa-file-export"></i></span>
                                <span>Export Data</span>
                            </a>
                        </div>
                    </div>
                </div>
                <!-- End Export/Import Section -->
            </div>

            <%- include('partials/_summary') %>

            <%- include('partials/_users') %>

            <%- include('partials/_deleted-elements') %>
        </main>
    </body>
</html>
