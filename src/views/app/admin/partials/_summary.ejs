<section class="mb-6">
    <h2 class="title is-4 mb-4"><%= __('admin_summary_title') %></h2>
    <div class="columns">
        <div class="column">
            <div class="box">
                <div class="is-flex is-justify-content-space-between is-align-items-center">
                    <div>
                        <p class="heading has-text-weight-semibold"><%= __('admin_total_users') %></p>
                        <p class="title is-3"><%= summary.totalUsers %></p>
                    </div>
                    <span class="icon is-large has-text-primary"> <!-- user icon -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </span>
                </div>
            </div>
        </div>

        <div class="column">
            <div class="box">
                <div class="is-flex is-justify-content-space-between is-align-items-center">
                    <div>
                        <p class="heading has-text-weight-semibold"><%= __('admin_total_projects') %></p>
                        <p class="title is-3"><%= summary.totalProjects %></p>
                    </div>
                    <span class="icon is-large has-text-link"> <!-- projects icon -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                    </span>
                </div>
            </div>
        </div>

        <div class="column">
            <div class="box">
                <div class="is-flex is-justify-content-space-between is-align-items-center">
                    <div>
                        <p class="heading has-text-weight-semibold"><%= __('admin_total_contractors') %></p>
                        <p class="title is-3"><%= summary.totalContractors %></p>
                    </div>
                    <span class="icon is-large has-text-success"> <!-- contractors icon -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>
