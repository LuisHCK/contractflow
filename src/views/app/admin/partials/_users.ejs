<section class="mb-6">
    <div class="is-flex is-flex-direction-row is-justify-content-space-between is-align-items-center mb-4">
    <h2 class="title is-4 mb-4"><%= __('admin_users_title') %></h2>
        <a href="/users/create" class="button is-small is-primary"><%= __('list_create') %> <%= __('user') %></a>
    </div>
    <% if (users.length === 0) { %>
        <div class="has-text-centered py-6">
            <p class="has-text-grey"><%= __('admin_users_no_data') %></p>
        </div>
    <% } else { %>
        <div class="columns is-multiline">
            <% users.forEach(user => { %>
                <div class="column is-12-mobile is-6-tablet is-4-desktop">
                    <article class="card is-fullheight">
                        <div class="card-content">
                            <div class="is-flex is-justify-content-space-between is-align-items-flex-start mb-4">
                                <div>
                                    <p class="title is-5 mb-1"><%= user.name || __('name') %></p>
                                    <p class="is-size-7 has-text-grey">ID&nbsp;<%= user.id %></p>
                                </div>
                                <div>
                                    <% if (user.active) { %>
                                        <span class="tag is-success is-light"><%= __('active') %></span>
                                    <% } else { %>
                                        <span class="tag is-danger is-light"><%= __('inactive') %></span>
                                    <% } %>
                                </div>
                            </div>

                            <div class="content mb-5">
                                <p class="mb-2">
                                    <span class="has-text-weight-semibold"><%= __('email') %>:</span>
                                    <span class="has-text-grey-dark"> <%= user.email %> </span>
                                </p>
                                <div class="mb-0 is-flex is-flex-direction-row is-align-items-center">
                                    <span class="has-text-weight-semibold mr-2"><%= __('role') %>:</span>
                                    <span class="tag is-secondary"><%= user.role %></span>
                                </div>
                            </div>
                        </div>
                        <footer class="card-footer">
                            <a href="/users/edit/<%= user.id %>" class="card-footer-item"><%= __('detail_edit') %></a>
                        </footer>
                    </article>
                </div>
            <% }) %>
        </div>
    <% } %>
</section>
