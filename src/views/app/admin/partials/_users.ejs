<section class="mb-6">
    <h2 class="title is-4 mb-4"><%= __('admin_users_title') %></h2>
    <div class="box">
        <% if (users.length === 0) { %>
            <div class="has-text-centered py-6">
                <p class="has-text-grey"><%= __('admin_users_no_data') %></p>
            </div>
        <% } else { %>
            <div class="table-container">
                <table class="table is-fullwidth is-striped is-hoverable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th><%= __('name') %></th>
                            <th><%= __('email') %></th>
                            <th><%= __('actions') %></th>
                            <th><%= __('status') %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(user => { %>
                            <tr>
                                <td><%= user.id %></td>
                                <td><%= user.name %></td>
                                <td><%= user.email %></td>
                                <td>
                                    <span class="tag is-info"><%= user.role %></span>
                                </td>
                                <td>
                                    <% if (user.active) { %>
                                        <span class="tag is-success"><%= __('active') %></span>
                                    <% } else { %>
                                        <span class="tag is-danger"><%= __('inactive') %></span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</section>
