<!DOCTYPE html>
<html lang="en" data-theme="light">
    <%- include('../../partials/head') %>

    <body class="container">
        <% for (let i = 0; i < 2; i++) { %>
        <section class="receipt-container">
            <div class="receipt-body">
                <h1 class="is-size-5">Payment Receipt</h1>
                <div>
                    <div class="has-text-right">
                        <b>Receipt #:</b>
                        <span class="is-underlined"> <%= payment.paymentNumber %> </span>
                    </div>

                    <div class="nowrap has-text-right">
                        <b>Payment Date:</b>
                        <span class="is-underlined"> <%= payment.createdAt %> </span>
                    </div>
                </div>

                <div class="">
                    <b>Amount: </b>
                    <span class="is-underlined">
                        <%= utils.formatToCurrency(payment.amount) %>
                    </span>
                </div>

                <div class="">
                    <b>In words:</b>
                    <span class="is-underlined"> <%= stage.estimatedCostWords %> </span>
                </div>

                <div class="">
                    <b>Received from:</b>
                    <span class="is-underlined"> <%= payment.payer %> </span>
                </div>

                <div class="">
                    <b>For payment of:</b>
                    <span class="is-underlined"> <%= payment.description %> </span>
                </div>

                <div class="span-col">
                    <b>Payment method:</b>
                    <span class="is-underlined"> <%= payment.paymentMethod %> </span>
                </div>

                <div class="">
                    <b>Received by:</b>
                    <span class="is-underlined"> <%= contractor.name %> </span>
                </div>

                <!-- Summary -->
                <table class="table is-bordered is-narrow is-dark-bordered">
                    <tbody>
                        <tr>
                            <td>Acc. Amount</td>
                            <td><%= utils.formatToCurrency(stage.estimatedCost) %></td>
                        </tr>
                        <tr>
                            <td>This payment</td>
                            <td><%= utils.formatToCurrency(payment.amount) %></td>
                        </tr>

                        <tr>
                            <td>Balance due:</td>
                            <td><%= utils.formatToCurrency(payment.balance) %></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <% if (i === 0) { %>
        <hr class="my-4 divider">
        <% } %>

        <% } %>
    </body>

    <style>
        body {
            font-size: small;
        }

        .receipt-container {
            border: 1px solid black;
            padding: 1rem;
        }

        .receipt-body {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5rem;
        }

        .receipt-body > h1 {
            white-space: nowrap;
        }

        .span-col {
            grid-column: 1 / span 2;
        }

        .nowrap {
            white-space: nowrap;
        }

        .divider {
            width: 100%;
            height: 1px;
            border-bottom: 1px dashed rgb(100, 100, 100);
        }
    </style>

    <script>
        window.addEventListener('DOMContentLoaded', function() {
            const params = new URLSearchParams(window.location.search);
            if (params.get('autoprint') === 'true') {
                window.print();
            }
        });
    </script>
</html>
