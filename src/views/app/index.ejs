<!DOCTYPE html>
<html lang="<%= locale %>" data-theme="<%= locals.theme || 'light' %>">
    <%- include('../partials/head') %>
    <body>
        <%- include('../partials/navigation') %>
        
        <main>
            <!-- Hero Section -->
            <section class="hero is-fullheight-with-navbar hero-background">
                <div class="hero-body px-0">
                    <div class="container is-max-widescreen px-4">
                        <div class="columns is-centered">
                            <div class="column is-8 has-text-centered">
                                <h1 class="title is-1 is-size-2-mobile is-family-serif text-balance mb-6">
                                    Project payments, simplified
                                </h1>
                                <p class="subtitle is-4 is-size-5-mobile has-text-grey text-balance mb-6" style="line-height: 1.6;">
                                    Track your projects and contractor payments in one place. Professional financial management built for modern teams.
                                </p>
                                <div class="buttons is-centered mt-6">
                                    <a href="/projects" class="button is-dark is-large">
                                        <span>Get Started</span>
                                        <span class="icon is-small ml-1">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M5 12h14"></path>
                                                <path d="m12 5 7 7-7 7"></path>
                                            </svg>
                                        </span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- How it works Section -->
            <section class="section is-medium py-24-custom">
                <div class="container is-max-widescreen">
                    <div class="has-text-centered mb-6">
                        <h2 class="title is-2 is-family-serif">
                            How it works
                        </h2>
                        <p class="subtitle has-text-grey">
                            Three simple steps to better payment tracking
                        </p>
                    </div>

                    <div class="columns is-variable is-8 mt-6">
                        <!-- Step 1 -->
                        <div class="column is-one-third">
                            <div class="step-number">
                                1
                            </div>
                            <h3 class="title is-4 is-family-serif">Setup</h3>
                            <p class="content has-text-grey">
                                Add your projects and contractors in minutes. Import from your existing tools or start fresh.
                            </p>
                        </div>

                        <!-- Step 2 -->
                        <div class="column is-one-third">
                            <div class="step-number">
                                2
                            </div>
                            <h3 class="title is-4 is-family-serif">Track</h3>
                            <p class="content has-text-grey">
                                Monitor project progress and payment milestones in real-time with automated notifications.
                            </p>
                        </div>

                        <!-- Step 3 -->
                        <div class="column is-one-third">
                            <div class="step-number">
                                3
                            </div>
                            <h3 class="title is-4 is-family-serif">Pay</h3>
                            <p class="content has-text-grey">
                                Process payments securely and maintain complete financial records for your business.
                            </p>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <footer class="footer">
            <div class="container is-max-widescreen">
                <div class="columns is-vcentered">
                    <div class="column">
                        <div class="is-flex is-align-items-center" style="gap: 1.5rem;">
                            <a href="#" class="has-text-grey hover:has-text-black">Privacy</a>
                            <a href="#" class="has-text-grey hover:has-text-black">Terms</a>
                            <a href="#" class="has-text-grey hover:has-text-black">Contact</a>
                        </div>
                    </div>
                    <div class="column is-narrow">
                        <p class="is-size-7 has-text-grey">© 2026 ContractorPay. All rights reserved.</p>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>
