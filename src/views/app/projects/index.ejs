<!DOCTYPE html>
<html lang="<%= locale %>" data-theme="<%= locals.theme || 'light' %>">
<%- include('../../partials/head') %>

    <body>
        <%- include('../../partials/navigation') %>

            <main class="container is-max-widescreen py-6 px-4">
                <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                    <ul>
                        <li><a href="/"> <%= __('breadcrumb_home') %> </a></li>
                        <li class="is-active"><a href="#"> <%= __('breadcrumb_projects') %> </a></li>
                    </ul>
                </nav>

                <div class="is-flex is-justify-content-space-between is-align-items-center mb-5 project-header">
                    <h1 class="title is-1 is-size-3-mobile"><%= __('projects_title') %></h1>
                    <div class="create-button-wrapper">
                        <a href="/projects/create" class="button is-primary is-medium-mobile">
                            <span class="icon is-small is-hidden-tablet mr-0">
                                <!-- plus icon -->
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </span>
                            <span class="is-hidden-mobile"><%= __('projects_add') %></span>
                        </a>
                    </div>
                </div>

                <!-- Project list -->
                <%- include('partials/_list', { projects }) %>
            </main>
    </body>

</html>
