<div class="table-container">
    <table class="table is-striped is-hoverable is-fullwidth">
        <thead>
            <tr class="is-<%= locals.theme || 'light' %>">
                <th><%= __('stages_name') %></th>
                <th><%= __('stages_estimated_cost') %></th>
                <th><%= __('stages_paid') %></th>
                <th><%= __('stages_progress') %></th>
                <th class="has-text-right"><%= __('stages_actions') %></th>
            </tr>
        </thead>
        <tbody>
            <% stages.forEach(stage=> { %>
                <tr>
                    <td>
                        <%= stage.name %>
                    </td>
                    <td>
                        <div class="tag is-dark">
                            $<%= stage.estimatedCost %>
                        </div>
                    </td>
                    <td>
                        <div class="tag is-info">
                            $<%= stage.totalPayments %>
                        </div>
                    </td>
                    <td>
                        <progress class="progress <% if (stage.progress >= 100) {%> is-success <%}%> "
                            value="<%= stage.progress %>" max="100">
                            <%= stage.progress %>%
                        </progress>

                    </td>
                    <td>
                        <div class="field is-grouped is-justify-content-flex-end">
                            <p class="control">
                                <a class="button primary is-small"
                                    href="/projects/show/<%= project.id %>/stages/show/<%= stage.id %>/payments/create">
                                    <%= __('stages_register_payment') %>
                                </a>
                            </p>
                            <p class="control">
                                <a class="button is-light is-small"
                                    href="/projects/show/<%= project.id %>/stages/show/<%= stage.id %>"><%= __('stages_view') %></a>
                            </p>
                            <p class="control">
                                <a class="button is-warning is-small"
                                    href="/projects/<%= project.id %>/stages/<%= stage.id %>/delete"><%= __('stages_delete') %></a>
                            </p>
                        </div>
                    </td>
                </tr>
            <% }); %>

            <!-- No stages message -->
            <% if (stages.length === 0) { %>
                <tr>
                    <td colspan="5">
                        <div class="notification is-warning has-text-centered">
                            <%= __('stages_no_stages') %>
                        </div>
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
