<% const statusStyles = {
    active: "is-success",
    paused: "is-warning",
    completed: "is-link",
    archived: "is-dark"
}; %>

<div class="columns is-multiline is-variable is-4">
    <% if (projects && projects.length) { %>
        <% projects.forEach(function (project) {
            const statusKey = (project.status || "unknown").toLowerCase();
            const statusClass = statusStyles[statusKey] || "is-info";
            const statusLabel = (project.status || "Unknown").replace(/_/g, " ");
        %>
        <div class="column is-full-tablet is-half-desktop">
            <div class="card">
                <header class="card-header">
                    <div class="card-header-title is-block">
                        <p class="title is-5 is-spaced"><%= project.name %></p>
                        <p class="subtitle is-6 has-text-grey">
                            <%= project.description || "No description provided" %>
                        </p>
                    </div>
                    <div class="card-header-icon">
                        <span class="tag <%= statusClass %> is-light is-uppercase"><%= statusLabel %></span>
                    </div>
                </header>

                <div class="card-content">
                    <div class="content">
                        <div class="columns is-mobile">
                            <div class="column">
                                <p class="heading">Start Date</p>
                                <p class="title is-6"><%= project.startDate %></p>
                            </div>
                            <div class="column">
                                <p class="heading">End Date</p>
                                <p class="title is-6"><%= project.endDate %></p>
                            </div>
                        </div>
                        <div class="columns is-mobile">
                            <div class="column">
                                <p class="heading">Created</p>
                                <p class="title is-6"><%= project.createdAt %></p>
                            </div>
                            <div class="column">
                                <p class="heading">Updated</p>
                                <p class="title is-6"><%= project.updatedAt %></p>
                            </div>
                        </div>
                        <% if (project.deleted) { %>
                            <span class="tag is-danger is-light is-uppercase">Archived</span>
                        <% } %>
                    </div>
                </div>

                <footer class="card-footer">
                    <a href="/projects/<%= project.id %>" class="card-footer-item has-text-weight-semibold">
                        View Details
                    </a>
                    <a href="/projects/<%= project.id %>/edit" class="card-footer-item has-text-weight-semibold">
                        Edit
                    </a>
                </footer>
            </div>
        </div>
        <% }); %>
    <% } else { %>
        <div class="column is-12">
            <div class="notification is-info is-light">
                There are no projects to display yet.
            </div>
        </div>
    <% } %>
</div>