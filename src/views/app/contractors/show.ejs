<!DOCTYPE html>
<html lang="<%= locale %>" data-theme="<%= locals.theme || 'light' %>">
    <%- include('../../partials/head', { title: `ContractorPay | ${contractor.name}` }) %>

    <body>
        <%- include('../../partials/navigation') %>

        <main class="container is-max-widescreen py-6 px-4">
            <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                <ul>
                    <li><a href="/"> <%= __('breadcrumb_home') %> </a></li>
                    <li><a href="/contractors"> <%= __('breadcrumb_contractors') %> </a></li>
                    <li class="is-active">
                        <a href="#" aria-current="page" class="has-text-dark"> <%= contractor.name %> </a>
                    </li>
                </ul>
            </nav>

            <div class="is-flex is-justify-content-space-between is-align-items-center">
                <h1 class="title is-1"><%= contractor.name %></h1>
                <a href="/contractors/edit/<%= contractor.id %>" class="button is-primary"> <%= __('contractor_edit') %> </a>
            </div>

            <h2 class="title is-5"><%= __('contractor_details') %></h2>

            <section class="box">
                <div class="columns">
                    <div class="column is-6">
                        <p class="block"><strong><%= __('contractor_name') %>:</strong> <%= contractor.name %></p>
                        <p class="block"><strong><%= __('contractor_email') %>:</strong> <%= contractor.email %></p>
                    </div>
                    <div class="column is-6">
                        <p class="block"><strong><%= __('contractor_phone') %>:</strong> <%= contractor.phone %></p>
                        <p class="block"><strong><%= __('contractor_address') %>:</strong> <%= contractor.address %></p>
                    </div>
                </div>
                <div class="columns">
                    <div class="column is-12">
                        <h3 class="title is-5"><%= __('contractor_notes') %></h3>
                        <p><%= contractor.notes %></p>
                    </div>
                </div>
                <div class="columns">
                    <div class="column is-12">
                        <h3 class="title is-5"><%= __('contractor_projects') %></h3>
                        <ul>
                            <% projects.forEach(project => { %>
                                <li>
                                    <a href="/projects/<%= project.id %>"><%= project.name %></a>
                                </li>
                            <% }) %>
                        </ul>
                    </div>
                </div>
            </section>
        </main>
    </body>
</html>
